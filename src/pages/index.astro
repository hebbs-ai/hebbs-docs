---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import MemoryEdge from "../components/MemoryEdge.astro";
import HowItWorks from "../components/HowItWorks.astro";
import OutOfTheBox from "../components/OutOfTheBox.astro";
import Vault from "../components/Vault.astro";
import MemoryPalaceDemo from "../components/MemoryPalaceDemo.astro";
import RecallStrategies from "../components/RecallStrategies.astro";
import Consolidation from "../components/Consolidation.astro";
import BlogSlider from "../components/BlogSlider.astro";
import CodeExample from "../components/CodeExample.astro";
import Deployment from "../components/Deployment.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="HEBBS — Make memory your edge">
  <Nav />
  <main>
    <!-- ── Dark hero ── -->
    <Hero />

    <!-- ── Narrative arc (dark, continues hero energy) ── -->
    <MemoryEdge />

    <!-- ── How it works + features (dark band) ── -->
    <div class="band-dark">
      <HowItWorks />
      <OutOfTheBox />
    </div>

    <!-- ── Vault (dark band) ── -->
    <div class="band-dark">
      <Vault />
    </div>

    <!-- ── Memory palace + strategies + consolidation + blog (dark band) ── -->
    <div class="band-dark">
      <MemoryPalaceDemo />
      <RecallStrategies />
      <Consolidation />
      <BlogSlider />
    </div>

    <!-- ── Code + deploy (dark band) ── -->
    <div class="band-dark">
      <CodeExample />
      <Deployment />
    </div>

    <!-- ── CTA (dark band) ── -->
    <div class="band-dark">
      <Cta />
    </div>
  </main>
  <Footer />
</Layout>
