---
// Legal vertical guide — docs.hebbs.ai/guide/legal
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Legal Research Agent &mdash; HEBBS Guide</title>
  <meta name="description" content="Give your firm real memory. Case history, statutes, precedents, and contradiction detection in one engine." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-snap-type: y proximity; }
    body { background: #0a0a0b; color: #d4d4d8; font-family: "Inter", ui-sans-serif, system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    ::selection { background: rgba(245, 158, 11, 0.3); }
    .stage { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 80px 24px; scroll-snap-align: start; position: relative; overflow: hidden; }
    .stage-inner { max-width: 900px; width: 100%; }
    .stage-num { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #f59e0b; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px; opacity: 0.7; }
    h2 { font-family: "Space Grotesk", sans-serif; font-size: clamp(28px, 5vw, 44px); font-weight: 700; color: #ededef; letter-spacing: -0.5px; line-height: 1.15; margin-bottom: 16px; }
    .subtitle { font-size: 17px; color: #8a8a8e; line-height: 1.6; max-width: 600px; margin-bottom: 32px; }
    .terminal { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; overflow: hidden; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.7; }
    .terminal-bar { display: flex; align-items: center; gap: 6px; padding: 12px 16px; border-bottom: 1px solid #1e1e20; }
    .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
    .terminal-dot.r { background: rgba(239,68,68,0.5); }
    .terminal-dot.y { background: rgba(245,158,11,0.5); }
    .terminal-dot.g { background: rgba(34,197,94,0.4); }
    .terminal-title { margin-left: 8px; font-size: 11px; color: #3f3f46; }
    .terminal-body { padding: 20px 24px; overflow-x: auto; }
    .terminal-body pre { white-space: pre; }
    .t-prompt { color: #f59e0b; } .t-cmd { color: #ededef; } .t-flag { color: #67e8f9; }
    .t-str { color: #34d399; } .t-out { color: #8a8a8e; } .t-num { color: #f59e0b; }
    .t-dim { color: #3f3f46; } .t-pass { color: #34d399; } .t-fail { color: #f87171; } .t-warn { color: #fbbf24; }
    .folder-tree { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.8; }
    .folder-tree .dir { color: #67e8f9; } .folder-tree .file { color: #8a8a8e; } .folder-tree .comment { color: #3f3f46; } .folder-tree .entity-tag { color: #f59e0b; }
    .copy-btn { position: absolute; top: 12px; right: 12px; background: #1e1e20; border: 1px solid #3f3f46; border-radius: 6px; padding: 4px 10px; font-family: "JetBrains Mono", monospace; font-size: 10px; color: #8a8a8e; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { color: #ededef; border-color: #8a8a8e; }
    .guide-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; gap: 4px; padding: 12px 24px; background: rgba(10, 10, 11, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid #1e1e20; }
    .guide-nav a { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #8a8a8e; text-decoration: none; padding: 6px 14px; border-radius: 6px; transition: all 0.2s; }
    .guide-nav a:hover { color: #d4d4d8; background: rgba(255,255,255,0.04); }
    .guide-nav a.active { color: #f59e0b; background: rgba(245,158,11,0.08); }
    .guide-nav .nav-back { color: #3f3f46; margin-right: 12px; padding-right: 16px; border-right: 1px solid #1e1e20; }
    .guide-nav .nav-back:hover { color: #8a8a8e; }
    .nav-dots { position: fixed; right: 24px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 100; }
    .nav-dot { width: 8px; height: 8px; border-radius: 50%; background: #1e1e20; border: none; cursor: pointer; transition: all 0.3s; padding: 0; }
    .nav-dot.active { background: #f59e0b; transform: scale(1.3); }
    .nav-dot:hover { background: #3f3f46; }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; }
    .cta-primary { background: #f59e0b; color: #0a0a0b; } .cta-primary:hover { background: #fbbf24; }
    .cta-secondary { border: 1px solid #1e1e20; color: #8a8a8e; } .cta-secondary:hover { border-color: #3f3f46; color: #d4d4d8; }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .workflow-step { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; }
    .workflow-num { font-family: "JetBrains Mono", monospace; font-size: 14px; color: #f59e0b; min-width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(245,158,11,0.3); border-radius: 50%; flex-shrink: 0; margin-top: 2px; }
    .workflow-content { flex: 1; }
    .workflow-content strong { color: #ededef; font-weight: 600; }
    .workflow-content p { color: #8a8a8e; font-size: 14px; line-height: 1.5; margin-top: 4px; }
    @media (max-width: 640px) { .stage { padding: 80px 16px 60px; } .terminal-body { padding: 16px; font-size: 11px; } .nav-dots { display: none; } .guide-nav { overflow-x: auto; } }
  </style>
</head>
<body>

  <nav class="guide-nav">
    <a href="/" class="nav-back">&larr; docs</a>
    <a href="/guide/">Guide</a>
    <a href="/guide/crm">CRM</a>
    <a href="/guide/legal" class="active">Legal</a>
    <a href="/guide/finance">Finance</a>
    <a href="/guide/support">Support</a>
    <a href="/guide/coding">Coding</a>
  </nav>

  <nav class="nav-dots" id="nav-dots">
    <button class="nav-dot active" data-stage="0" title="Setup"></button>
    <button class="nav-dot" data-stage="1" title="Workflow"></button>
    <button class="nav-dot" data-stage="2" title="Intelligence"></button>
    <button class="nav-dot" data-stage="3" title="Start"></button>
  </nav>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 1: Your Legal Workspace                                   -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-0">
    <div class="stage-inner fade-up">
      <div class="stage-num">Your Legal Workspace</div>
      <h2>Legal Research Agent</h2>
      <p class="subtitle">One workspace for the firm. Entities per case or client. Shared knowledge every attorney can draw from.</p>

      <div class="folder-tree">
        <pre><span class="dir">workspace/</span>
<span class="dir">  entities/</span>                          <span class="comment">&larr; one folder per case or client</span>
<span class="dir">    smith-v-jones/</span>
<span class="file">      deposition-2026-03-10.md</span>      <span class="entity-tag">&rarr; entity_id: "smith-v-jones"</span>
<span class="file">      motion-to-dismiss.md</span>          <span class="entity-tag">&rarr; entity_id: "smith-v-jones"</span>
<span class="file">      case-timeline.md</span>              <span class="entity-tag">&rarr; entity_id: "smith-v-jones"</span>
<span class="dir">    doe-estate/</span>
<span class="file">      trust-document.md</span>             <span class="entity-tag">&rarr; entity_id: "doe-estate"</span>
<span class="dir">  statutes/</span>                          <span class="comment">&larr; shared knowledge</span>
<span class="file">    securities-act.md</span>
<span class="file">    gdpr-articles.md</span>
<span class="dir">  precedents/</span>
<span class="file">    landmark-privacy-rulings.md</span>
<span class="dir">  templates/</span>
<span class="file">    motion-template.md</span>
<span class="dir">  firm-policies/</span>
<span class="file">    billing-guidelines.md</span>
<span class="file">    conflict-check-process.md</span></pre>
      </div>

      <p style="margin-top: 20px; font-size: 14px; color: #8a8a8e; line-height: 1.6;">
        <strong style="color: #ededef;">Why one workspace?</strong> When an attorney asks "brief me on Smith v. Jones," prime needs to search case memory AND statutes AND precedents in a single query. Separate workspaces can't cross-reference. Entities give you per-case isolation while keeping everything queryable together.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 2: Daily Workflow                                         -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-1">
    <div class="stage-inner fade-up">
      <div class="stage-num">Daily Workflow</div>
      <h2>From intake to close</h2>
      <p class="subtitle">Drop files, log via CLI, or wire up SDK integrations. Every interaction becomes memory.</p>

      <div class="workflow-step">
        <div class="workflow-num">1</div>
        <div class="workflow-content">
          <strong>New case comes in</strong>
          <p>Create the entity folder. Drop your case files.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">new case</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/smith-v-jones</span>
<span class="t-prompt">$</span> <span class="t-cmd">vim entities/smith-v-jones/deposition-2026-03-10.md</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>
<span class="t-pass">  &#10003; 1 new file &middot; entity: smith-v-jones</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">2</div>
        <div class="workflow-content">
          <strong>Research with prime</strong>
          <p>Prime loads case history AND relevant statutes AND precedents in one shot.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">case briefing</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs prime</span> <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span>

<span class="t-out">Entity memory:</span>
<span class="t-dim">  2026-03-10</span>  Deposition: plaintiff alleges data breach on Feb 2, 2026
<span class="t-dim">  2026-03-14</span>  Motion to dismiss filed, citing lack of standing
<span class="t-dim">  2026-03-20</span>  Judge denied motion. Discovery phase begins April 1.

<span class="t-out">Shared knowledge surfaced:</span>
<span class="t-str">  statutes/gdpr-articles.md</span>            GDPR Art. 33 breach notification timeline
<span class="t-str">  precedents/landmark-privacy-rulings.md</span>  Williams v. DataCorp supports standing
<span class="t-str">  statutes/securities-act.md</span>            SEC disclosure requirements if publicly traded
<span class="t-str">  templates/motion-template.md</span>          Template for motion to compel discovery</pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">3</div>
        <div class="workflow-content">
          <strong>Log research and case developments</strong>
          <p>CLI for quick notes, files for formal memos.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">ongoing</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># Quick note after a hearing</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Judge ruled motion to compel granted. \
  Must produce documents by April 15."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span> <span class="t-flag">--importance</span> <span class="t-num">0.9</span>

<span class="t-pass">  &#10003; Stored</span>

<span class="t-dim"># Found a relevant precedent</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Found precedent: Williams v. DataCorp (2024) \
  supports our privacy argument"</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span> <span class="t-flag">--importance</span> <span class="t-num">0.8</span>

<span class="t-pass">  &#10003; Stored</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">4</div>
        <div class="workflow-content">
          <strong>Ask strategic questions anytime</strong>
          <p>Temporal, causal, analogical, similarity: different strategies for different questions.</p>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">strategic recall</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># "What's the full procedural history?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"procedural history of smith-v-jones"</span> <span class="t-flag">--strategy</span> <span class="t-str">temporal</span> <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span>

<span class="t-dim"># "What precedents led to this ruling?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"precedents that led to the standing ruling"</span> \
  <span class="t-flag">--strategy</span> <span class="t-str">causal</span> <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span>

<span class="t-dim"># "What arguments worked in similar privacy cases?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"arguments that succeeded in privacy breach cases"</span> \
  <span class="t-flag">--strategy</span> <span class="t-str">analogical</span>

<span class="t-dim"># "Find statutes about data retention"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"statutes about data retention obligations"</span> <span class="t-flag">-k</span> <span class="t-num">5</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 3: Case Intelligence                                      -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-2">
    <div class="stage-inner fade-up">
      <div class="stage-num">Case Intelligence</div>
      <h2>Precedents no research tool can trace</h2>
      <p class="subtitle">Contradictions catch conflicting clauses. Causal chains trace precedent lineage. Insights reveal what wins cases. All automatic.</p>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">contradiction detection</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-warn">&#9888; Contradictions detected:</span>

<span class="t-warn">  smith-v-jones:</span>
<span class="t-out">    "Contract Clause 7.1 says data retained 3 years"</span>
<span class="t-out">     vs "Clause 12.4 says deleted after 1 year"</span>
<span class="t-dim">     Direct conflict in retention obligations. Flag for opposing counsel review.</span></pre>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">causal chain</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"how does Williams v. DataCorp support our motion?"</span> \
  <span class="t-flag">--strategy</span> <span class="t-str">causal</span> <span class="t-flag">--entity-id</span> <span class="t-str">smith-v-jones</span>

<span class="t-out">Precedent chain:</span>
<span class="t-str">  Williams v. DataCorp (2024)</span>
<span class="t-dim">    &rarr; Set privacy standard for breach notification timing</span>
<span class="t-str">    &rarr; Cited in Brown v. TechInc (2025)</span>
<span class="t-dim">       &rarr; Extended standard to cover third-party processors</span>
<span class="t-str">       &rarr; Supports our motion</span>
<span class="t-dim">          &rarr; Defendant's data processor failed notification deadline</span>
<span class="t-dim">          &rarr; Same fact pattern as Smith v. Jones</span></pre>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">firm-wide insights</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs reflect</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs insights</span> <span class="t-flag">--min-confidence</span> <span class="t-num">0.7</span>

<span class="t-num">1</span>  <span class="t-pass">0.91</span>  Cases with early expert witness identification
              settled 40% faster. Smith v. Jones has not yet
              retained an expert.

<span class="t-num">2</span>  <span class="t-pass">0.86</span>  Privacy arguments citing EU precedents had higher
              success rate in federal court. Consider adding GDPR
              analysis to the Smith v. Jones brief.

<span class="t-num">3</span>  <span class="t-pass">0.82</span>  Motions filed within 7 days of discovery deadline
              were granted at 2x the rate of last-minute filings.

<span class="t-num">4</span>  <span class="t-warn">0.74</span>  Cases where document production was completed early
              saw 30% fewer sanctions motions from opposing counsel.</pre>
        </div>
      </div>

      <div style="margin-top: 24px; background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px;">
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #3f3f46; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Tuning Profile: Legal/Compliance</p>
        <p style="font-size: 13px; color: #8a8a8e; line-height: 1.6;">
          When you <a href="/guide/#stage-6" style="color: #f59e0b; text-decoration: none;">tune retrieval</a>, the Legal profile prioritizes factual lookup (40%), entity-scoped recall (20%), temporal queries (15%), contradiction detection (15%), and cross-entity pattern matching (10%). The compiled rules optimize for "find the exact clause" and "what precedents support this argument."
        </p>
      </div>

      <div style="margin-top: 24px; background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px;">
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #3f3f46; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">GDPR Forget: Real Deletion</p>
        <p style="font-size: 13px; color: #8a8a8e; line-height: 1.6;">
          Attorney-client privilege and confidentiality require real deletion, not soft flags. <code style="font-family: 'JetBrains Mono', monospace; color: #67e8f9; font-size: 12px;">hebbs forget --entity-id doe-estate</code> permanently removes all memories, embeddings, and derived insights for that entity. No tombstones, no recoverable traces. Compliance-ready by design.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 4: CTA                                                    -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-3">
    <div class="stage-inner fade-up" style="text-align: center;">
      <h2>Your firm deserves memory,<br/>not memo hunting.</h2>

      <div class="terminal" style="max-width: 580px; margin: 32px auto; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
        </div>
        <div class="terminal-body" style="text-align: left;">
          <pre><span class="t-dim"># Start a new case</span>
<span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/new-case</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>

<span class="t-dim"># Brief yourself instantly</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs prime --entity-id new-case</span>
<span class="t-pass">  &#10003; Your legal workspace is ready.</span></pre>
        </div>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('mkdir entities/new-case && hebbs index && hebbs prime --entity-id new-case')">copy</button>
      </div>

      <div style="display: flex; gap: 16px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
        <a href="/guide/" class="cta-btn cta-primary">Back to full guide</a>
        <a href="/getting-started/quickstart/" class="cta-btn cta-secondary">Full docs</a>
      </div>

      <p style="margin-top: 40px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #3f3f46;">
        No re-reading depositions &middot; No missing precedents &middot; No conflicting clauses &middot; Just memory
      </p>
    </div>
  </section>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    const stages = document.querySelectorAll('.stage');
    const dots = document.querySelectorAll('.nav-dot');
    const stageObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = [...stages].indexOf(e.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.4 });
    stages.forEach(s => stageObs.observe(s));
    dots.forEach(d => d.addEventListener('click', () => {
      stages[parseInt(d.dataset.stage)].scrollIntoView({ behavior: 'smooth' });
    }));
  </script>
</body>
</html>
