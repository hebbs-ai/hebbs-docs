    <div class="stage-inner fade-up" style="text-align: center;">
      <h2>Your agent deserves real memory.</h2>
      <p class="subtitle" style="margin: 0 auto 40px;">Pick your use case. Same engine, your domain.</p>

      <div class="vertical-grid">
        <a href="/guide/crm" class="vertical-card">
          <div class="v-icon">&#128188;</div>
          <div class="v-title">CRM</div>
          <div class="v-desc">Deal memory + company knowledge. Prime before calls. Catch pipeline contradictions. Learn what closes deals.</div>
        </a>
        <a href="/guide/legal" class="vertical-card">
          <div class="v-icon">&#9878;</div>
          <div class="v-title">Legal</div>
          <div class="v-desc">Causal chains through case law. Trace precedents. Detect conflicting clauses. Consolidate case strategy.</div>
        </a>
        <a href="/guide/finance" class="vertical-card">
          <div class="v-icon">&#128200;</div>
          <div class="v-title">Finance</div>
          <div class="v-desc">Policy vs practice contradictions. Compliance cross-referencing. Audit trail reconstruction.</div>
        </a>
        <a href="/guide/support" class="vertical-card">
          <div class="v-icon">&#127899;</div>
          <div class="v-title">Support</div>
          <div class="v-desc">Ticket history + similar resolutions. Auto-generated runbooks. Org gets smarter with every ticket.</div>
        </a>
        <a href="/guide/coding" class="vertical-card">
          <div class="v-icon">&#128187;</div>
          <div class="v-title">Coding</div>
          <div class="v-desc">Remember what was tried. Recall why it failed. Avoid repeating mistakes across projects.</div>
        </a>
      </div>

      <div style="margin-top: 48px;">
        <div class="terminal" style="max-width: 540px; margin: 0 auto; position: relative;">
          <div class="terminal-bar">
            <span class="terminal-dot r"></span>
            <span class="terminal-dot y"></span>
            <span class="terminal-dot g"></span>
          </div>
          <div class="terminal-body" style="text-align: left;">
            <pre><span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/my-first-entity</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs prime --entity-id my-first-entity</span>
<span class="t-pass">  &#10003; Memory is ready.</span></pre>
          </div>
          <button class="copy-btn" onclick="navigator.clipboard.writeText('mkdir entities/my-first-entity && hebbs index && hebbs prime --entity-id my-first-entity')">copy all</button>
        </div>
      </div>

      <div style="display: flex; gap: 16px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
        <a href="/getting-started/quickstart/" class="cta-btn cta-primary">Read the full docs</a>
        <a href="https://github.com/hebbs-ai/hebbs" target="_blank" rel="noopener" class="cta-btn cta-secondary">GitHub</a>
      </div>

      <p style="margin-top: 40px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #3f3f46;">
        4 recall strategies &middot; Auto entity scoping &middot; Contradiction detection &middot; Self-tuning retrieval &middot; 1 binary
      </p>
    </div>
  </section>

  <script>
    // ═══════════════════════════════════════════════════════════════════
    // HERO: Bioluminescent particle graph
    // ═══════════════════════════════════════════════════════════════════
    (function() {
      const canvas = document.getElementById('hero-graph');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      let W, H, nodes = [], raf;

      const COLORS = [
        [245, 158, 11],   // amber
        [103, 232, 249],  // cyan
        [52, 211, 153],   // green
        [167, 139, 250],  // purple
        [248, 113, 113],  // red (contradiction)
      ];

      function resize() {
        const r = canvas.getBoundingClientRect();
        W = r.width; H = r.height;
        canvas.width = W * dpr; canvas.height = H * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function createNodes() {
        nodes = [];
        const count = Math.min(60, Math.floor(W * H / 12000));
        for (let i = 0; i < count; i++) {
          const col = COLORS[Math.floor(Math.random() * COLORS.length)];
          nodes.push({
            x: Math.random() * W, y: Math.random() * H,
            vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4,
            r: 2 + Math.random() * 4,
            col, pulse: Math.random() * Math.PI * 2,
            importance: 0.3 + Math.random() * 0.7,
          });
        }
      }

      function draw() {
        ctx.clearRect(0, 0, W, H);
        const t = performance.now() * 0.001;

        // Edges
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const dx = b.x - a.x, dy = b.y - a.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 140) {
              const alpha = (1 - dist / 140) * 0.15;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
              ctx.strokeStyle = `rgba(${a.col[0]},${a.col[1]},${a.col[2]},${alpha})`;
              ctx.lineWidth = 1;
              ctx.stroke();
            }
          }
        }

        // Nodes
        for (const n of nodes) {
          n.x += n.vx; n.y += n.vy;
          if (n.x < 0 || n.x > W) n.vx *= -1;
          if (n.y < 0 || n.y > H) n.vy *= -1;

          const glow = 0.5 + 0.5 * Math.sin(t * 1.5 + n.pulse);
          const r = n.r * (0.8 + 0.4 * glow);

          // Outer glow
          const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, r * 4);
          grad.addColorStop(0, `rgba(${n.col[0]},${n.col[1]},${n.col[2]},${0.15 * n.importance})`);
          grad.addColorStop(1, 'rgba(0,0,0,0)');
          ctx.beginPath(); ctx.arc(n.x, n.y, r * 4, 0, Math.PI * 2);
          ctx.fillStyle = grad; ctx.fill();

          // Core
          ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${n.col[0]},${n.col[1]},${n.col[2]},${0.6 + 0.3 * glow})`;
          ctx.fill();
        }

        raf = requestAnimationFrame(draw);
      }

      resize(); createNodes(); draw();
      window.addEventListener('resize', () => { resize(); createNodes(); });
    })();

    // ═══════════════════════════════════════════════════════════════════
    // TYPING ANIMATION for terminal blocks
    // ═══════════════════════════════════════════════════════════════════
    (function() {
      const terminals = document.querySelectorAll('.terminal[data-typing]');
      const typedSet = new Set();

      function typeTerminal(terminal) {
        if (typedSet.has(terminal)) return;
        typedSet.add(terminal);

        const pre = terminal.querySelector('.terminal-body pre');
        if (!pre) return;

        const fullHTML = pre.innerHTML;
        const lines = fullHTML.split('\n');
        pre.innerHTML = '';
        pre.style.visibility = 'visible';

        let lineIdx = 0;
        const cursor = document.createElement('span');
        cursor.className = 'cursor';

        function addLine() {
          if (lineIdx >= lines.length) {
            cursor.remove();
            return;
          }
          if (lineIdx > 0) pre.innerHTML = pre.innerHTML.replace(/<span class="cursor"><\/span>$/, '') + '\n';

          const line = lines[lineIdx];
          const isCommand = line.includes('t-prompt') || line.includes('t-cmd');
          lineIdx++;

          if (isCommand) {
            // Type command lines character by character (visual effect)
            pre.insertAdjacentHTML('beforeend', line);
            pre.appendChild(cursor);
            setTimeout(addLine, 80 + Math.random() * 60);
          } else {
            // Output lines appear instantly
            pre.insertAdjacentHTML('beforeend', line);
            pre.appendChild(cursor);
            setTimeout(addLine, 30);
          }
        }

        addLine();
      }

      const tObs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) typeTerminal(e.target);
        });
      }, { threshold: 0.5 });

      terminals.forEach(t => {
        const pre = t.querySelector('.terminal-body pre');
        if (pre) pre.style.visibility = 'hidden';
        tObs.observe(t);
      });
    })();

    // ═══════════════════════════════════════════════════════════════════
    // FADE-IN on scroll
    // ═══════════════════════════════════════════════════════════════════
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // ═══════════════════════════════════════════════════════════════════
    // NAV DOTS (includes hero)
    // ═══════════════════════════════════════════════════════════════════
    const allSections = document.querySelectorAll('.hero, .stage');
    const dots = document.querySelectorAll('.nav-dot');
    const stageObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = [...allSections].indexOf(e.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.4 });
    allSections.forEach(s => stageObs.observe(s));
    dots.forEach(d => d.addEventListener('click', () => {
      const id = d.dataset.stage;
      const target = id === 'hero' ? document.getElementById('hero') : document.getElementById('stage-' + id);
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    }));

    // ═══════════════════════════════════════════════════════════════════
    // INPUT PATH TABS
    // ═══════════════════════════════════════════════════════════════════
    document.querySelectorAll('.path-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const p = tab.dataset.path;
        document.querySelectorAll('.path-tab').forEach(t => t.classList.toggle('active', t.dataset.path === p));
        document.querySelectorAll('.path-content').forEach(c => c.classList.toggle('active', c.dataset.path === p));
      });
    });

    // ═══════════════════════════════════════════════════════════════════
    // RECALL CARDS
    // ═══════════════════════════════════════════════════════════════════
    document.querySelectorAll('.recall-card').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll('.recall-card').forEach(c => c.classList.remove('active'));
        card.classList.add('active');
      });
    });
  </script>
</body>
</html>
