---
// Coding Agent vertical guide — memdocs.hebbs.ai/guide/coding
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Coding Agent Memory &mdash; HEBBS Guide</title>
  <meta name="description" content="Give your coding agent real memory. Decision history, architecture docs, and compounding engineering intelligence in one engine." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-snap-type: y proximity; }
    body { background: #0a0a0b; color: #d4d4d8; font-family: "Inter", ui-sans-serif, system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    ::selection { background: rgba(245, 158, 11, 0.3); }
    .stage { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 80px 24px; scroll-snap-align: start; position: relative; overflow: hidden; }
    .stage-inner { max-width: 900px; width: 100%; }
    .stage-num { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #f59e0b; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px; opacity: 0.7; }
    h2 { font-family: "Space Grotesk", sans-serif; font-size: clamp(28px, 5vw, 44px); font-weight: 700; color: #ededef; letter-spacing: -0.5px; line-height: 1.15; margin-bottom: 16px; }
    .subtitle { font-size: 17px; color: #8a8a8e; line-height: 1.6; max-width: 600px; margin-bottom: 32px; }
    .terminal { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; overflow: hidden; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.7; }
    .terminal-bar { display: flex; align-items: center; gap: 6px; padding: 12px 16px; border-bottom: 1px solid #1e1e20; }
    .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
    .terminal-dot.r { background: rgba(239,68,68,0.5); }
    .terminal-dot.y { background: rgba(245,158,11,0.5); }
    .terminal-dot.g { background: rgba(34,197,94,0.4); }
    .terminal-title { margin-left: 8px; font-size: 11px; color: #3f3f46; }
    .terminal-body { padding: 20px 24px; overflow-x: auto; }
    .terminal-body pre { white-space: pre; }
    .t-prompt { color: #f59e0b; } .t-cmd { color: #ededef; } .t-flag { color: #67e8f9; }
    .t-str { color: #34d399; } .t-out { color: #8a8a8e; } .t-num { color: #f59e0b; }
    .t-dim { color: #3f3f46; } .t-pass { color: #34d399; } .t-fail { color: #f87171; } .t-warn { color: #fbbf24; }
    .folder-tree { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.8; }
    .folder-tree .dir { color: #67e8f9; } .folder-tree .file { color: #8a8a8e; } .folder-tree .comment { color: #3f3f46; } .folder-tree .entity-tag { color: #f59e0b; }
    .copy-btn { position: absolute; top: 12px; right: 12px; background: #1e1e20; border: 1px solid #3f3f46; border-radius: 6px; padding: 4px 10px; font-family: "JetBrains Mono", monospace; font-size: 10px; color: #8a8a8e; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { color: #ededef; border-color: #8a8a8e; }
    .guide-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; gap: 4px; padding: 12px 24px; background: rgba(10, 10, 11, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid #1e1e20; }
    .guide-nav a { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #8a8a8e; text-decoration: none; padding: 6px 14px; border-radius: 6px; transition: all 0.2s; }
    .guide-nav a:hover { color: #d4d4d8; background: rgba(255,255,255,0.04); }
    .guide-nav a.active { color: #f59e0b; background: rgba(245,158,11,0.08); }
    .guide-nav .nav-back { color: #3f3f46; margin-right: 12px; padding-right: 16px; border-right: 1px solid #1e1e20; }
    .guide-nav .nav-back:hover { color: #8a8a8e; }
    .nav-dots { position: fixed; right: 24px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 100; }
    .nav-dot { width: 8px; height: 8px; border-radius: 50%; background: #1e1e20; border: none; cursor: pointer; transition: all 0.3s; padding: 0; }
    .nav-dot.active { background: #f59e0b; transform: scale(1.3); }
    .nav-dot:hover { background: #3f3f46; }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; }
    .cta-primary { background: #f59e0b; color: #0a0a0b; } .cta-primary:hover { background: #fbbf24; }
    .cta-secondary { border: 1px solid #1e1e20; color: #8a8a8e; } .cta-secondary:hover { border-color: #3f3f46; color: #d4d4d8; }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .workflow-step { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; }
    .workflow-num { font-family: "JetBrains Mono", monospace; font-size: 14px; color: #f59e0b; min-width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(245,158,11,0.3); border-radius: 50%; flex-shrink: 0; margin-top: 2px; }
    .workflow-content { flex: 1; }
    .workflow-content strong { color: #ededef; font-weight: 600; }
    .workflow-content p { color: #8a8a8e; font-size: 14px; line-height: 1.5; margin-top: 4px; }
    @media (max-width: 640px) { .stage { padding: 80px 16px 60px; } .terminal-body { padding: 16px; font-size: 11px; } .nav-dots { display: none; } .guide-nav { overflow-x: auto; } }
  </style>
</head>
<body>

  <nav class="guide-nav">
    <a href="/" class="nav-back">&larr; docs</a>
    <a href="/guide/">Guide</a>
    <a href="/guide/crm">CRM</a>
    <a href="/guide/legal">Legal</a>
    <a href="/guide/finance">Finance</a>
    <a href="/guide/support">Support</a>
    <a href="/guide/coding" class="active">Coding</a>
  </nav>

  <nav class="nav-dots" id="nav-dots">
    <button class="nav-dot active" data-stage="0" title="Setup"></button>
    <button class="nav-dot" data-stage="1" title="Workflow"></button>
    <button class="nav-dot" data-stage="2" title="Intelligence"></button>
    <button class="nav-dot" data-stage="3" title="Start"></button>
  </nav>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 1: Your Coding Workspace                                  -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-0">
    <div class="stage-inner fade-up">
      <div class="stage-num">Your Workspace</div>
      <h2>Coding Agent Memory</h2>
      <p class="subtitle">One workspace per team or org. Entities per project, feature, or refactor. Shared knowledge: architecture docs, ADRs, conventions.</p>

      <div class="folder-tree">
        <pre><span class="dir">workspace/</span>
<span class="dir">  entities/</span>                          <span class="comment">&larr; one folder per project or feature</span>
<span class="dir">    auth-refactor/</span>
<span class="file">      decision-log.md</span>               <span class="entity-tag">&rarr; entity_id: "auth-refactor"</span>
<span class="file">      approach-1-failed.md</span>           <span class="entity-tag">&rarr; entity_id: "auth-refactor"</span>
<span class="file">      approach-2-working.md</span>          <span class="entity-tag">&rarr; entity_id: "auth-refactor"</span>
<span class="dir">    payments-v2/</span>
<span class="file">      design-doc.md</span>                 <span class="entity-tag">&rarr; entity_id: "payments-v2"</span>
<span class="file">      migration-plan.md</span>             <span class="entity-tag">&rarr; entity_id: "payments-v2"</span>
<span class="dir">  architecture/</span>                      <span class="comment">&larr; shared knowledge</span>
<span class="file">    system-overview.md</span>
<span class="file">    database-schema.md</span>
<span class="file">    api-design-principles.md</span>
<span class="dir">  adrs/</span>
<span class="file">    adr-001-use-postgres.md</span>
<span class="file">    adr-007-event-sourcing.md</span>
<span class="file">    adr-012-auth-strategy.md</span>
<span class="dir">  conventions/</span>
<span class="file">    code-style.md</span>
<span class="file">    testing-guidelines.md</span>
<span class="file">    pr-review-checklist.md</span>
<span class="dir">  debugging/</span>
<span class="file">    common-postgres-issues.md</span>
<span class="file">    memory-leak-patterns.md</span></pre>
      </div>

      <p style="margin-top: 20px; font-size: 14px; color: #8a8a8e; line-height: 1.6;">
        <strong style="color: #ededef;">Why one workspace?</strong> When an agent asks "what was tried on auth?", prime needs to search decision logs AND architecture docs AND ADRs in a single query. Separate workspaces can't cross-reference. Entities give you per-project isolation while keeping everything queryable together.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 2: Daily Workflow                                         -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-1">
    <div class="stage-inner fade-up">
      <div class="stage-num">Daily Workflow</div>
      <h2>From feature to merge</h2>
      <p class="subtitle">Create entity folders, log decisions via CLI, and let prime surface everything relevant before you write a line of code.</p>

      <div class="workflow-step">
        <div class="workflow-num">1</div>
        <div class="workflow-content">
          <strong>Start a feature</strong>
          <p>Create the entity folder. Drop your design doc or decision log.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">new feature</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/auth-refactor</span>
<span class="t-prompt">$</span> <span class="t-cmd">vim entities/auth-refactor/decision-log.md</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>
<span class="t-pass">  &#10003; 1 new file &middot; entity: auth-refactor</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">2</div>
        <div class="workflow-content">
          <strong>Load context with prime</strong>
          <p>Prime surfaces decision history, relevant ADRs, architecture constraints, and past approaches that failed.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">context loading</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs prime</span> <span class="t-flag">--entity-id</span> <span class="t-str">auth-refactor</span>

<span class="t-out">Entity memory:</span>
<span class="t-dim">  2026-03-20</span>  Decision log created. Goal: replace JWT refresh with something stateful.
<span class="t-dim">  2026-03-21</span>  Approach 1: sliding-window JWT refresh. Race condition with multiple tabs.
<span class="t-dim">  2026-03-24</span>  Approach 2: opaque token + server-side session. Eliminates race condition.

<span class="t-out">Shared knowledge surfaced:</span>
<span class="t-str">  adrs/adr-012-auth-strategy.md</span>        Current auth architecture decisions
<span class="t-str">  architecture/system-overview.md</span>       Service boundaries and auth flow
<span class="t-str">  conventions/testing-guidelines.md</span>     Auth tests require integration suite
<span class="t-str">  debugging/common-postgres-issues.md</span>   Session table locking under load</pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">3</div>
        <div class="workflow-content">
          <strong>Log decisions and approaches</strong>
          <p>CLI for quick notes during debugging and coding. Capture what worked, what failed, and why.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">logging decisions</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># Log a failed approach</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Tried JWT refresh with sliding window. \
  Race condition when multiple tabs open simultaneously."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">auth-refactor</span> <span class="t-flag">--importance</span> <span class="t-num">0.8</span>

<span class="t-pass">  &#10003; Stored</span>

<span class="t-dim"># Log the working solution</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Switched to opaque token + server-side session. \
  Eliminates race condition. ADR-012 updated."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">auth-refactor</span> <span class="t-flag">--importance</span> <span class="t-num">0.9</span>

<span class="t-pass">  &#10003; Stored</span>

<span class="t-dim"># Log a constraint discovered on another project</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Payments migration: batch size >5000 \
  causes OOM on staging. Set to 2000 with backpressure."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">payments-v2</span> <span class="t-flag">--importance</span> <span class="t-num">0.8</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">4</div>
        <div class="workflow-content">
          <strong>Ask strategic questions anytime</strong>
          <p>Temporal, causal, similarity, analogical &mdash; different strategies for different engineering questions.</p>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">strategic recall</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># "What approaches have we tried on auth?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"auth-refactor approach history"</span> <span class="t-flag">--strategy</span> <span class="t-str">temporal</span> <span class="t-flag">--entity-id</span> <span class="t-str">auth-refactor</span>

<span class="t-dim"># "What caused the OOM during migration?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"OOM during payments migration"</span> <span class="t-flag">--strategy</span> <span class="t-str">causal</span> <span class="t-flag">--entity-id</span> <span class="t-str">payments-v2</span>

<span class="t-dim"># "Find ADRs about session management"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"session management architecture decisions"</span> \
  <span class="t-flag">--strategy</span> <span class="t-str">similarity</span>

<span class="t-dim"># "How did we handle similar race conditions in payments?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"race condition resolution patterns"</span> \
  <span class="t-flag">--strategy</span> <span class="t-str">analogical</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 3: Engineering Intelligence                               -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-2">
    <div class="stage-inner fade-up">
      <div class="stage-num">Engineering Intelligence</div>
      <h2>Lessons that compound across projects</h2>
      <p class="subtitle">Reflect consolidates patterns across projects. Contradictions catch architectural drift. Insights reveal what actually ships well.</p>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">temporal recall &mdash; decision chain</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"auth-refactor full history"</span> <span class="t-flag">--strategy</span> <span class="t-str">temporal</span> <span class="t-flag">--entity-id</span> <span class="t-str">auth-refactor</span>

<span class="t-out">Decision chain for auth-refactor:</span>
<span class="t-dim">  2026-03-20</span>  Goal defined: replace JWT refresh with stateful alternative
<span class="t-dim">  2026-03-21</span>  <span class="t-fail">Approach 1: sliding-window JWT &mdash; FAILED</span>
<span class="t-dim">            </span>  <span class="t-out">Race condition when multiple tabs open simultaneously</span>
<span class="t-dim">  2026-03-24</span>  <span class="t-pass">Approach 2: opaque token + server-side session &mdash; WORKING</span>
<span class="t-dim">            </span>  <span class="t-out">Eliminates race condition. ADR-012 updated.</span>
<span class="t-dim">  2026-03-26</span>  Integration tests passing. Session table indexed on token_hash.</pre>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">cross-project insights</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs reflect</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs insights</span> <span class="t-flag">--min-confidence</span> <span class="t-num">0.7</span>

<span class="t-num">1</span>  <span class="t-pass">0.93</span>  Batch operations over 5000 records consistently cause
              OOM on staging &mdash; pattern observed in payments-v2
              and data-export projects.

<span class="t-num">2</span>  <span class="t-pass">0.89</span>  Features with a design doc reviewed before coding had
              40% fewer reverts.

<span class="t-num">3</span>  <span class="t-pass">0.85</span>  Race conditions in concurrent systems were resolved by
              switching from optimistic to pessimistic locking in
              3 of 4 cases.

<span class="t-num">4</span>  <span class="t-warn">0.78</span>  Migration scripts that include rollback procedures had
              zero production incidents.</pre>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">contradiction &mdash; auto-detected</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-warn">&#9888; Contradiction detected:</span>

<span class="t-warn">  adrs/adr-007-event-sourcing.md</span>
<span class="t-out">    "Use event sourcing for all audit trail requirements"</span>
<span class="t-out">     vs</span>
<span class="t-warn">  entities/payments-v2/design-doc.md</span>
<span class="t-out">    "Payments audit trail uses direct writes to audit_log table"</span>
<span class="t-dim">     Flagged for architecture review.</span></pre>
        </div>
      </div>

      <div style="margin-top: 24px; background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px;">
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #3f3f46; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Tuning Profile: Engineering</p>
        <p style="font-size: 13px; color: #8a8a8e; line-height: 1.6;">
          When you <a href="/guide/#stage-6" style="color: #f59e0b; text-decoration: none;">tune retrieval</a>, the Engineering profile prioritizes causal queries (25%), entity-scoped recall (25%), factual lookup (20%), temporal recall (20%), and broad sweep (10%). The compiled rules optimize for "what caused this bug" and "what was tried before."
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 4: CTA                                                    -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-3">
    <div class="stage-inner fade-up" style="text-align: center;">
      <h2>Your codebase deserves memory,<br/>not lost context.</h2>

      <div class="terminal" style="max-width: 580px; margin: 32px auto; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
        </div>
        <div class="terminal-body" style="text-align: left;">
          <pre><span class="t-dim"># Start a new feature</span>
<span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/new-feature</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>

<span class="t-dim"># Load full context</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs prime --entity-id new-feature</span>
<span class="t-pass">  &#10003; Your coding agent is ready.</span></pre>
        </div>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('mkdir entities/new-feature && hebbs index && hebbs prime --entity-id new-feature')">copy</button>
      </div>

      <div style="display: flex; gap: 16px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
        <a href="/guide/" class="cta-btn cta-primary">Back to full guide</a>
        <a href="/getting-started/quickstart/" class="cta-btn cta-secondary">Full docs</a>
      </div>

      <p style="margin-top: 40px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #3f3f46;">
        No re-debugging &middot; No lost decisions &middot; No forgotten approaches &middot; Just memory
      </p>
    </div>
  </section>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    const stages = document.querySelectorAll('.stage');
    const dots = document.querySelectorAll('.nav-dot');
    const stageObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = [...stages].indexOf(e.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.4 });
    stages.forEach(s => stageObs.observe(s));
    dots.forEach(d => d.addEventListener('click', () => {
      stages[parseInt(d.dataset.stage)].scrollIntoView({ behavior: 'smooth' });
    }));
  </script>
</body>
</html>
