---
// Finance vertical guide — memdocs.hebbs.ai/guide/finance
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Finance &amp; Compliance &mdash; HEBBS Guide</title>
  <meta name="description" content="Give your compliance team real memory. Audit findings, regulatory cross-references, and contradiction detection in one engine." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-snap-type: y proximity; }
    body { background: #0a0a0b; color: #d4d4d8; font-family: "Inter", ui-sans-serif, system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
    ::selection { background: rgba(245, 158, 11, 0.3); }
    .stage { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 80px 24px; scroll-snap-align: start; position: relative; overflow: hidden; }
    .stage-inner { max-width: 900px; width: 100%; }
    .stage-num { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #f59e0b; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px; opacity: 0.7; }
    h2 { font-family: "Space Grotesk", sans-serif; font-size: clamp(28px, 5vw, 44px); font-weight: 700; color: #ededef; letter-spacing: -0.5px; line-height: 1.15; margin-bottom: 16px; }
    .subtitle { font-size: 17px; color: #8a8a8e; line-height: 1.6; max-width: 600px; margin-bottom: 32px; }
    .terminal { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; overflow: hidden; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.7; }
    .terminal-bar { display: flex; align-items: center; gap: 6px; padding: 12px 16px; border-bottom: 1px solid #1e1e20; }
    .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
    .terminal-dot.r { background: rgba(239,68,68,0.5); }
    .terminal-dot.y { background: rgba(245,158,11,0.5); }
    .terminal-dot.g { background: rgba(34,197,94,0.4); }
    .terminal-title { margin-left: 8px; font-size: 11px; color: #3f3f46; }
    .terminal-body { padding: 20px 24px; overflow-x: auto; }
    .terminal-body pre { white-space: pre; }
    .t-prompt { color: #f59e0b; } .t-cmd { color: #ededef; } .t-flag { color: #67e8f9; }
    .t-str { color: #34d399; } .t-out { color: #8a8a8e; } .t-num { color: #f59e0b; }
    .t-dim { color: #3f3f46; } .t-pass { color: #34d399; } .t-fail { color: #f87171; } .t-warn { color: #fbbf24; }
    .folder-tree { background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px; font-family: "JetBrains Mono", monospace; font-size: 13px; line-height: 1.8; }
    .folder-tree .dir { color: #67e8f9; } .folder-tree .file { color: #8a8a8e; } .folder-tree .comment { color: #3f3f46; } .folder-tree .entity-tag { color: #f59e0b; }
    .copy-btn { position: absolute; top: 12px; right: 12px; background: #1e1e20; border: 1px solid #3f3f46; border-radius: 6px; padding: 4px 10px; font-family: "JetBrains Mono", monospace; font-size: 10px; color: #8a8a8e; cursor: pointer; transition: all 0.2s; }
    .copy-btn:hover { color: #ededef; border-color: #8a8a8e; }
    .guide-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; display: flex; align-items: center; gap: 4px; padding: 12px 24px; background: rgba(10, 10, 11, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid #1e1e20; }
    .guide-nav a { font-family: "JetBrains Mono", monospace; font-size: 12px; color: #8a8a8e; text-decoration: none; padding: 6px 14px; border-radius: 6px; transition: all 0.2s; }
    .guide-nav a:hover { color: #d4d4d8; background: rgba(255,255,255,0.04); }
    .guide-nav a.active { color: #f59e0b; background: rgba(245,158,11,0.08); }
    .guide-nav .nav-back { color: #3f3f46; margin-right: 12px; padding-right: 16px; border-right: 1px solid #1e1e20; }
    .guide-nav .nav-back:hover { color: #8a8a8e; }
    .nav-dots { position: fixed; right: 24px; top: 50%; transform: translateY(-50%); display: flex; flex-direction: column; gap: 12px; z-index: 100; }
    .nav-dot { width: 8px; height: 8px; border-radius: 50%; background: #1e1e20; border: none; cursor: pointer; transition: all 0.3s; padding: 0; }
    .nav-dot.active { background: #f59e0b; transform: scale(1.3); }
    .nav-dot:hover { background: #3f3f46; }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; }
    .cta-primary { background: #f59e0b; color: #0a0a0b; } .cta-primary:hover { background: #fbbf24; }
    .cta-secondary { border: 1px solid #1e1e20; color: #8a8a8e; } .cta-secondary:hover { border-color: #3f3f46; color: #d4d4d8; }
    .fade-up { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease-out, transform 0.7s ease-out; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .workflow-step { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; }
    .workflow-num { font-family: "JetBrains Mono", monospace; font-size: 14px; color: #f59e0b; min-width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(245,158,11,0.3); border-radius: 50%; flex-shrink: 0; margin-top: 2px; }
    .workflow-content { flex: 1; }
    .workflow-content strong { color: #ededef; font-weight: 600; }
    .workflow-content p { color: #8a8a8e; font-size: 14px; line-height: 1.5; margin-top: 4px; }
    @media (max-width: 640px) { .stage { padding: 80px 16px 60px; } .terminal-body { padding: 16px; font-size: 11px; } .nav-dots { display: none; } .guide-nav { overflow-x: auto; } }
  </style>
</head>
<body>

  <nav class="guide-nav">
    <a href="/" class="nav-back">&larr; docs</a>
    <a href="/guide/">Guide</a>
    <a href="/guide/crm">CRM</a>
    <a href="/guide/legal">Legal</a>
    <a href="/guide/finance" class="active">Finance</a>
    <a href="/guide/support">Support</a>
    <a href="/guide/coding">Coding</a>
  </nav>

  <nav class="nav-dots" id="nav-dots">
    <button class="nav-dot active" data-stage="0" title="Setup"></button>
    <button class="nav-dot" data-stage="1" title="Workflow"></button>
    <button class="nav-dot" data-stage="2" title="Intelligence"></button>
    <button class="nav-dot" data-stage="3" title="Start"></button>
  </nav>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 1: Your Finance Workspace                                 -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-0">
    <div class="stage-inner fade-up">
      <div class="stage-num">Your Workspace</div>
      <h2>Finance &amp; Compliance Agent</h2>
      <p class="subtitle">One workspace for the team. Entities per audit, review, or project. Shared knowledge: regulations, policies, standards.</p>

      <div class="folder-tree">
        <pre><span class="dir">workspace/</span>
<span class="dir">  entities/</span>                          <span class="comment">&larr; one folder per audit or project</span>
<span class="dir">    audit-2026-q1/</span>
<span class="file">      findings-draft.md</span>              <span class="entity-tag">&rarr; entity_id: "audit-2026-q1"</span>
<span class="file">      evidence-log.md</span>                <span class="entity-tag">&rarr; entity_id: "audit-2026-q1"</span>
<span class="file">      management-response.md</span>         <span class="entity-tag">&rarr; entity_id: "audit-2026-q1"</span>
<span class="dir">    vendor-risk-review/</span>
<span class="file">      cloudvault-assessment.md</span>       <span class="entity-tag">&rarr; entity_id: "vendor-risk-review"</span>
<span class="dir">  regulations/</span>                        <span class="comment">&larr; shared knowledge</span>
<span class="file">    sox-section-404.md</span>
<span class="file">    gdpr-articles.md</span>
<span class="file">    pci-dss-v4.md</span>
<span class="dir">  policies/</span>
<span class="file">    data-retention-policy.md</span>
<span class="file">    access-control-policy.md</span>
<span class="dir">  standards/</span>
<span class="file">    iso-27001-controls.md</span>
<span class="dir">  past-audits/</span>
<span class="file">    audit-2025-q4-final.md</span></pre>
      </div>

      <p style="margin-top: 20px; font-size: 14px; color: #8a8a8e; line-height: 1.6;">
        <strong style="color: #ededef;">Why one workspace?</strong> When an auditor asks "what regulations apply to this finding," prime needs to search audit findings AND regulatory docs AND past audit results AND internal policies in a single query. Separate workspaces can't cross-reference. Entities give you per-audit isolation while keeping everything queryable together.
      </p>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 2: Daily Workflow                                         -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-1">
    <div class="stage-inner fade-up">
      <div class="stage-num">Daily Workflow</div>
      <h2>From finding to report</h2>
      <p class="subtitle">Drop files, log via CLI, or wire up SDK integrations. Every finding becomes memory.</p>

      <div class="workflow-step">
        <div class="workflow-num">1</div>
        <div class="workflow-content">
          <strong>New audit starts</strong>
          <p>Create the entity folder. Drop your initial scope docs.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">new audit</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/audit-2026-q1</span>
<span class="t-prompt">$</span> <span class="t-cmd">vim entities/audit-2026-q1/findings-draft.md</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>
<span class="t-pass">  &#10003; 1 new file &middot; entity: audit-2026-q1</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">2</div>
        <div class="workflow-content">
          <strong>Cross-reference with prime</strong>
          <p>Prime loads current findings AND relevant regulations AND past audit results AND policies in one shot.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">audit briefing</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs prime</span> <span class="t-flag">--entity-id</span> <span class="t-str">audit-2026-q1</span>

<span class="t-out">Entity memory:</span>
<span class="t-dim">  2026-03-01</span>  Scope: Internal controls over financial reporting (ICFR)
<span class="t-dim">  2026-03-05</span>  Access logs show 3 admin accounts with no MFA enabled
<span class="t-dim">  2026-03-08</span>  S3 bucket lifecycle set to 90-day deletion

<span class="t-out">Regulations &amp; policies surfaced:</span>
<span class="t-str">  regulations/sox-section-404.md</span>      Section 404 &mdash; management assessment of controls
<span class="t-str">  policies/access-control-policy.md</span>   AC-102: all privileged access requires MFA
<span class="t-str">  policies/data-retention-policy.md</span>   7-year retention for financial records
<span class="t-str">  past-audits/audit-2025-q4-final.md</span>  Similar access control finding in Q4</pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">3</div>
        <div class="workflow-content">
          <strong>Log findings as they emerge</strong>
          <p>CLI for quick observations. Files for formal evidence logs.</p>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">ongoing findings</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># Quick finding after evidence review</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Access logs show 3 admin accounts with no MFA \
  enabled. Violates policy AC-102."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">audit-2026-q1</span> <span class="t-flag">--importance</span> <span class="t-num">0.9</span>

<span class="t-pass">  &#10003; Stored</span>
<span class="t-warn">  &#9888; Contradiction: policy says all access requires MFA,
     but 3 admin accounts found without MFA (confidence: 0.95)</span>

<span class="t-dim"># Vendor review update</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs remember</span> <span class="t-str">"Vendor Cloudvault renewed SOC2 Type II. \
  Expires 2027-01."</span> \
  <span class="t-flag">--entity-id</span> <span class="t-str">vendor-risk-review</span> <span class="t-flag">--importance</span> <span class="t-num">0.7</span></pre>
        </div>
      </div>

      <div class="workflow-step">
        <div class="workflow-num">4</div>
        <div class="workflow-content">
          <strong>Ask strategic questions anytime</strong>
          <p>Temporal, causal, similarity, analogical &mdash; different strategies for different questions.</p>
        </div>
      </div>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">strategic recall</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-dim"># "How have access control findings evolved?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"access control findings across quarters"</span> <span class="t-flag">--strategy</span> <span class="t-str">temporal</span>

<span class="t-dim"># "What caused the 2025 breach?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"What led to the 2025 data breach?"</span> <span class="t-flag">--strategy</span> <span class="t-str">causal</span>

<span class="t-dim"># "Find all PCI-DSS encryption requirements"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"PCI-DSS requirements about encryption at rest"</span> <span class="t-flag">--strategy</span> <span class="t-str">similarity</span>

<span class="t-dim"># "What remediation worked before?"</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs recall</span> <span class="t-str">"remediation for similar access control gaps"</span> <span class="t-flag">--strategy</span> <span class="t-str">analogical</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 3: Compliance Intelligence                                -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-2">
    <div class="stage-inner fade-up">
      <div class="stage-num">Compliance Intelligence</div>
      <h2>Contradictions no spreadsheet can catch</h2>
      <p class="subtitle">Contradictions surface policy violations automatically. Insights reveal systemic patterns. Both happen at index time.</p>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">contradiction &mdash; auto-detected</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-warn">&#9888; Contradictions detected during indexing:</span>

<span class="t-warn">  audit-2026-q1 &times; policies/data-retention-policy.md:</span>
<span class="t-out">    "Data retention policy says 7 years" (policy)</span>
<span class="t-out">     vs "S3 bucket lifecycle set to 90 days" (evidence-log.md)</span>
<span class="t-dim">     Financial records may be deleted before retention period expires.</span>

<span class="t-warn">  audit-2026-q1 &times; policies/access-control-policy.md:</span>
<span class="t-out">    "All access requires MFA" (policy AC-102)</span>
<span class="t-out">     vs "3 admin accounts found without MFA" (findings-draft.md)</span>
<span class="t-dim">     Privileged accounts in direct violation of internal policy.</span></pre>
        </div>
      </div>

      <div class="terminal" style="margin-bottom: 24px;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
          <span class="terminal-title">audit insights</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-prompt">$</span> <span class="t-cmd">hebbs reflect</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs insights</span> <span class="t-flag">--min-confidence</span> <span class="t-num">0.7</span>

<span class="t-num">1</span>  <span class="t-pass">0.91</span>  Access control findings repeat in Q1 and Q3 &mdash;
              correlates with new hire onboarding waves.

<span class="t-num">2</span>  <span class="t-pass">0.86</span>  Vendors with expiring SOC2 reports within 90 days
              had 2x more findings than vendors with current certs.

<span class="t-num">3</span>  <span class="t-pass">0.83</span>  Data retention violations cluster in cloud storage.
              On-prem systems pass retention checks consistently.

<span class="t-num">4</span>  <span class="t-warn">0.74</span>  Remediation timelines for access control gaps average
              45 days when escalated to CISO, 90+ days otherwise.</pre>
        </div>
      </div>

      <p style="font-size: 14px; color: #8a8a8e; line-height: 1.6;">
        Surface these before the audit committee meeting. The system learns what findings recur, what remediation actually works, and where policy gaps hide. Compliance intelligence compounds.
      </p>

      <div style="margin-top: 24px; background: #141415; border: 1px solid #1e1e20; border-radius: 12px; padding: 20px 24px;">
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #3f3f46; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">Tuning Profile: Legal/Compliance</p>
        <p style="font-size: 13px; color: #8a8a8e; line-height: 1.6;">
          When you <a href="/guide/#stage-6" style="color: #f59e0b; text-decoration: none;">tune retrieval</a>, the compliance profile prioritizes factual lookup (40%), entity-scoped recall (20%), temporal queries (15%), contradiction detection (15%), and cross-entity pattern matching (10%). The compiled rules optimize for regulatory cross-referencing and numeric disagreement detection.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- STAGE 4: CTA                                                    -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="stage" id="stage-3">
    <div class="stage-inner fade-up" style="text-align: center;">
      <h2>Your audits deserve<br/>memory, not spreadsheets.</h2>

      <div class="terminal" style="max-width: 580px; margin: 32px auto; position: relative;">
        <div class="terminal-bar">
          <span class="terminal-dot r"></span>
          <span class="terminal-dot y"></span>
          <span class="terminal-dot g"></span>
        </div>
        <div class="terminal-body" style="text-align: left;">
          <pre><span class="t-dim"># Start your first audit</span>
<span class="t-prompt">$</span> <span class="t-cmd">mkdir entities/new-audit</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs index</span>

<span class="t-dim"># Brief yourself on the scope</span>
<span class="t-prompt">$</span> <span class="t-cmd">hebbs prime --entity-id new-audit</span>
<span class="t-pass">  &#10003; Your compliance workspace is ready.</span></pre>
        </div>
        <button class="copy-btn" onclick="navigator.clipboard.writeText('mkdir entities/new-audit && hebbs index && hebbs prime --entity-id new-audit')">copy</button>
      </div>

      <div style="display: flex; gap: 16px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
        <a href="/guide/" class="cta-btn cta-primary">Back to full guide</a>
        <a href="/getting-started/quickstart/" class="cta-btn cta-secondary">Full docs</a>
      </div>

      <p style="margin-top: 40px; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #3f3f46;">
        No missed contradictions &middot; No stale policies &middot; No repeating findings &middot; Just memory
      </p>
    </div>
  </section>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    const stages = document.querySelectorAll('.stage');
    const dots = document.querySelectorAll('.nav-dot');
    const stageObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const idx = [...stages].indexOf(e.target);
          dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        }
      });
    }, { threshold: 0.4 });
    stages.forEach(s => stageObs.observe(s));
    dots.forEach(d => d.addEventListener('click', () => {
      stages[parseInt(d.dataset.stage)].scrollIntoView({ behavior: 'smooth' });
    }));
  </script>
</body>
</html>
