---
---

<section id="hero" class="relative overflow-hidden" style="background: #050510; min-height: 100vh;">
  <!-- WebGL Canvas -->
  <canvas id="hero-gl" class="absolute inset-0 w-full h-full" style="cursor: crosshair;"></canvas>

  <!-- Gradient overlays for text readability -->
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(135deg, rgba(5,5,16,0.85) 0%, rgba(5,5,16,0.4) 40%, rgba(5,5,16,0.1) 100%);"></div>
  <div class="absolute bottom-0 left-0 right-0 h-48 pointer-events-none" style="background: linear-gradient(to top, #050510, transparent);"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-5xl px-6 pt-44 pb-32 md:pt-56 md:pb-40">
    <div class="max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[4px] mb-6" style="color: #F59E0B; opacity: 0.7;">
        The memory engine for AI agents
      </p>

      <h1 class="font-logo text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.95] mb-8" style="color: #F8FAFC;">
        Make memory<br/>
        <span style="background: linear-gradient(135deg, #F59E0B 0%, #F97316 40%, #FB923C 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">your edge.</span>
      </h1>

      <p class="text-lg md:text-xl leading-relaxed mb-12 max-w-xl" style="color: #94A3B8;">
        LLMs are converging. Every team gets the same models. The agent that remembers better, retrieves smarter, and improves over time wins.<br class="hidden md:block"/>
        <span style="color: #CBD5E1; font-weight: 500;">That's not RAG. That's HEBBS.</span>
      </p>

      <div class="flex flex-wrap items-center gap-4 mb-16">
        <a
          href="https://docs.hebbs.ai/guide/"
          target="_blank"
          rel="noopener"
          class="group rounded-xl px-8 py-4 text-sm font-semibold transition-all duration-300"
          style="background: linear-gradient(135deg, #F59E0B, #D97706); color: #0a0a0b;"
          onmouseover="this.style.boxShadow='0 0 30px rgba(245,158,11,0.4)'"
          onmouseout="this.style.boxShadow='none'"
        >
          Get started
          <svg class="inline-block ml-2 w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a
          href="mailto:parag@hebbs.ai"
          class="rounded-xl px-8 py-4 text-sm font-semibold transition-all duration-300"
          style="border: 1px solid rgba(255,255,255,0.1); color: #94A3B8;"
          onmouseover="this.style.borderColor='rgba(245,158,11,0.4)'; this.style.color='#F8FAFC'"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='#94A3B8'"
        >
          Book a demo
        </a>
      </div>

      <div class="flex flex-wrap items-center gap-8 font-mono text-xs" style="color: #475569;">
        <div>
          <span style="color: #F59E0B; font-size: 20px; font-weight: 700;">4</span>
          <span class="ml-1.5">recall strategies</span>
        </div>
        <div>
          <span style="color: #67E8F9; font-size: 20px; font-weight: 700;">&lt;5ms</span>
          <span class="ml-1.5">retrieval</span>
        </div>
        <div>
          <span style="color: #34D399; font-size: 20px; font-weight: 700;">1</span>
          <span class="ml-1.5">binary</span>
        </div>
        <div>
          <span style="color: #F87171; font-size: 20px; font-weight: 700;">0</span>
          <span class="ml-1.5">dependencies</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2" style="color: #334155;">
    <span class="font-mono text-[10px] uppercase tracking-[3px]">scroll</span>
    <div class="w-px h-8 relative overflow-hidden">
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, #F59E0B, transparent); animation: scroll-drop 2s ease-in-out infinite;"></div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-drop {
    0% { transform: translateY(-100%); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: translateY(100%); opacity: 0; }
  }
</style>

<script is:inline>
(function() {
  // ═══════════════════════════════════════════════════════════════
  // WebGL2 Fluid Membrane — tiles + liquid flow + neuron glow
  // Pure WebGL2, zero dependencies
  // ═══════════════════════════════════════════════════════════════

  var canvas = document.getElementById('hero-gl');
  if (!canvas) return;

  var gl = canvas.getContext('webgl2', { alpha: true, antialias: false, premultipliedAlpha: false });
  if (!gl) {
    // Fallback: simple gradient for old browsers
    canvas.style.background = 'linear-gradient(135deg, #050510, #0a1628)';
    return;
  }

  // ── Shader sources ──

  var VS = `#version 300 es
    in vec2 a_pos;
    void main() { gl_Position = vec4(a_pos, 0.0, 1.0); }
  `;

  var FS = `#version 300 es
    precision highp float;
    out vec4 fragColor;

    uniform vec2 u_res;
    uniform float u_time;
    uniform vec2 u_mouse;       // normalized mouse pos (0-1)
    uniform float u_mouseSpeed; // mouse velocity magnitude
    uniform vec2 u_mouseDir;    // mouse velocity direction

    // ── Simplex-ish noise ──
    vec3 mod289(vec3 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
    vec2 mod289(vec2 x) { return x - floor(x * (1.0/289.0)) * 289.0; }
    vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

    float snoise(vec2 v) {
      const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                         -0.577350269189626, 0.024390243902439);
      vec2 i = floor(v + dot(v, C.yy));
      vec2 x0 = v - i + dot(i, C.xx);
      vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
      vec4 x12 = x0.xyxy + C.xxzz;
      x12.xy -= i1;
      i = mod289(i);
      vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
      vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
      m = m*m; m = m*m;
      vec3 x = 2.0 * fract(p * C.www) - 1.0;
      vec3 h = abs(x) - 0.5;
      vec3 ox = floor(x + 0.5);
      vec3 a0 = x - ox;
      m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
      vec3 g;
      g.x = a0.x * x0.x + h.x * x0.y;
      g.yz = a0.yz * x12.xz + h.yz * x12.yw;
      return 130.0 * dot(m, g);
    }

    // ── Fluid trail: mouse leaves a fading wake ──
    // We simulate this with distance-based falloff + directional stretch
    float fluidField(vec2 uv, vec2 mpos, vec2 mdir, float speed) {
      vec2 d = uv - mpos;
      // Stretch along mouse direction (anisotropic)
      float along = dot(d, mdir);
      float perp = length(d - along * mdir);
      // Wake extends behind the mouse
      float wake = smoothstep(0.0, -0.3, along) * exp(-perp * perp * 60.0);
      // Radial proximity
      float prox = exp(-dot(d,d) * 15.0);
      return (prox + wake * speed * 2.0);
    }

    void main() {
      vec2 uv = gl_FragCoord.xy / u_res;
      float aspect = u_res.x / u_res.y;
      vec2 uvA = vec2(uv.x * aspect, uv.y); // aspect-corrected

      float t = u_time;

      // ══════════════════════════════════════════════
      // 1. TILE GRID
      // ══════════════════════════════════════════════
      float tileSize = 0.035;
      float gap = 0.003;
      vec2 tileUV = uvA / tileSize;
      vec2 tileID = floor(tileUV);
      vec2 tileLocal = fract(tileUV);

      // Gap: create borders between tiles
      float border = step(gap / tileSize, tileLocal.x) *
                     step(gap / tileSize, tileLocal.y) *
                     (1.0 - step(1.0 - gap / tileSize, tileLocal.x)) *
                     (1.0 - step(1.0 - gap / tileSize, tileLocal.y));
      // Rounded corners
      vec2 fromCenter = abs(tileLocal - 0.5) * 2.0;
      float cornerDist = length(max(fromCenter - 0.7, 0.0));
      float rounded = 1.0 - smoothstep(0.2, 0.3, cornerDist);

      float tileMask = border * rounded;

      // ══════════════════════════════════════════════
      // 2. SIDE SPLIT: stock (left) vs HEBBS (right)
      // ══════════════════════════════════════════════
      float midX = 0.45; // shifted left so hero text stays readable
      float hebbsMix = smoothstep(midX - 0.05, midX + 0.05, uv.x);

      // ══════════════════════════════════════════════
      // 3. MOUSE FLUID INTERACTION
      // ══════════════════════════════════════════════
      vec2 mouseA = vec2(u_mouse.x * aspect, u_mouse.y);
      float fluid = fluidField(uvA, mouseA, u_mouseDir, u_mouseSpeed);

      // Noise-based organic flow
      float flow1 = snoise(uvA * 3.0 + t * 0.15) * 0.5 + 0.5;
      float flow2 = snoise(uvA * 5.0 - t * 0.1 + 100.0) * 0.5 + 0.5;
      float flow3 = snoise(uvA * 8.0 + t * 0.08 + 200.0) * 0.5 + 0.5;

      // ══════════════════════════════════════════════
      // 4. TILE COLOR
      // ══════════════════════════════════════════════

      // Per-tile noise (varies by tile position)
      float tileNoise = snoise(tileID * 0.3 + t * 0.05);
      float tileRand = fract(sin(dot(tileID, vec2(12.9898, 78.233))) * 43758.5453);

      // Distance from mouse to tile center
      vec2 tileCenterA = (tileID + 0.5) * tileSize;
      float mouseDist = length(tileCenterA - mouseA);
      float mouseInfluence = exp(-mouseDist * mouseDist * 8.0) * (0.5 + u_mouseSpeed * 2.0);

      // ── Stock side: dim monochrome ──
      vec3 stockColor = vec3(0.08, 0.08, 0.12);
      float stockBright = 0.03 + tileRand * 0.02 + tileNoise * 0.01;
      stockColor += stockBright;

      // ── HEBBS side: alive, colorful, reactive ──
      // Base: dark with subtle color variation
      vec3 hebbsBase = vec3(0.04, 0.05, 0.08);

      // Flowing color channels
      float r = flow1 * 0.6 + flow2 * 0.3;
      float g = flow2 * 0.4 + flow3 * 0.5;
      float b = flow3 * 0.5 + flow1 * 0.2;

      // Color palette: amber, cyan, green based on tile position
      vec3 amber = vec3(0.96, 0.62, 0.04);   // #F59E0B
      vec3 cyan  = vec3(0.40, 0.91, 0.98);   // #67E8F9
      vec3 green = vec3(0.20, 0.83, 0.60);   // #34D399
      vec3 purple = vec3(0.65, 0.55, 0.98);  // #A78BFA

      // Assign color per tile based on noise
      vec3 tileColor;
      float colorPick = fract(tileRand * 7.0 + tileNoise * 0.5);
      if (colorPick < 0.35) tileColor = amber;
      else if (colorPick < 0.55) tileColor = cyan;
      else if (colorPick < 0.75) tileColor = green;
      else tileColor = purple;

      // Organic brightness pulse per tile
      float pulse = sin(t * (0.8 + tileRand * 1.5) + tileRand * 6.28) * 0.5 + 0.5;
      float brightness = 0.04 + pulse * 0.08 * (0.5 + tileNoise * 0.5);

      // Mouse proximity boost: tiles near cursor glow strongly
      brightness += mouseInfluence * 0.5;

      // Occasional bright "activation" tiles
      float activation = step(0.92, sin(t * 0.3 + tileRand * 50.0) * 0.5 + 0.5 + mouseInfluence * 0.3);
      brightness += activation * 0.3;

      vec3 hebbsColor = hebbsBase + tileColor * brightness;

      // ── Fluid color bleed: mouse leaves colored trail ──
      vec3 fluidColor = mix(amber, cyan, flow1) * fluid * 0.4 * hebbsMix;
      hebbsColor += fluidColor;

      // ══════════════════════════════════════════════
      // 5. COMPOSE
      // ══════════════════════════════════════════════
      vec3 color = mix(stockColor, hebbsColor, hebbsMix);

      // Apply tile mask (gaps between tiles are dark)
      color *= tileMask;

      // Add very subtle glow to gaps on HEBBS side (energy between tiles)
      float gapGlow = (1.0 - tileMask) * hebbsMix * 0.015 * (1.0 + fluid * 3.0);
      vec3 gapColor = mix(amber, cyan, flow2) * gapGlow;
      color += gapColor;

      // ── Edge vignette ──
      float vignette = 1.0 - dot(uv - 0.5, uv - 0.5) * 1.2;
      color *= vignette;

      // ── Subtle scan lines for futuristic feel ──
      float scanline = 0.97 + 0.03 * sin(gl_FragCoord.y * 1.5);
      color *= scanline;

      fragColor = vec4(color, 1.0);
    }
  `;

  // ── Compile shaders ──
  function createShader(type, src) {
    var s = gl.createShader(type);
    gl.shaderSource(s, src);
    gl.compileShader(s);
    if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
      console.error('Shader error:', gl.getShaderInfoLog(s));
      gl.deleteShader(s);
      return null;
    }
    return s;
  }

  var vs = createShader(gl.VERTEX_SHADER, VS);
  var fs = createShader(gl.FRAGMENT_SHADER, FS);
  if (!vs || !fs) return;

  var prog = gl.createProgram();
  gl.attachShader(prog, vs);
  gl.attachShader(prog, fs);
  gl.linkProgram(prog);
  if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
    console.error('Link error:', gl.getProgramInfoLog(prog));
    return;
  }
  gl.useProgram(prog);

  // ── Full-screen quad ──
  var quad = new Float32Array([-1,-1, 1,-1, -1,1, 1,1]);
  var buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, quad, gl.STATIC_DRAW);

  var aPos = gl.getAttribLocation(prog, 'a_pos');
  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

  // ── Uniforms ──
  var uRes = gl.getUniformLocation(prog, 'u_res');
  var uTime = gl.getUniformLocation(prog, 'u_time');
  var uMouse = gl.getUniformLocation(prog, 'u_mouse');
  var uMouseSpeed = gl.getUniformLocation(prog, 'u_mouseSpeed');
  var uMouseDir = gl.getUniformLocation(prog, 'u_mouseDir');

  // ── State ──
  var mouseX = 0.7, mouseY = 0.5;
  var prevMouseX = 0.7, prevMouseY = 0.5;
  var mouseSpeed = 0, mouseDirX = 0, mouseDirY = 0;
  var startTime = performance.now();

  function resize() {
    var dpr = Math.min(window.devicePixelRatio || 1, 2); // cap at 2x for perf
    var r = canvas.getBoundingClientRect();
    canvas.width = r.width * dpr;
    canvas.height = r.height * dpr;
    gl.viewport(0, 0, canvas.width, canvas.height);
  }

  function render() {
    var now = (performance.now() - startTime) * 0.001;

    // Smooth mouse velocity
    var dx = mouseX - prevMouseX;
    var dy = mouseY - prevMouseY;
    var speed = Math.sqrt(dx * dx + dy * dy);
    mouseSpeed = mouseSpeed * 0.85 + speed * 0.15 * 60; // smooth + scale
    if (speed > 0.0001) {
      mouseDirX = mouseDirX * 0.8 + (dx / speed) * 0.2;
      mouseDirY = mouseDirY * 0.8 + (dy / speed) * 0.2;
    }
    prevMouseX = mouseX;
    prevMouseY = mouseY;

    gl.uniform2f(uRes, canvas.width, canvas.height);
    gl.uniform1f(uTime, now);
    gl.uniform2f(uMouse, mouseX, mouseY);
    gl.uniform1f(uMouseSpeed, Math.min(mouseSpeed, 3.0));
    gl.uniform2f(uMouseDir, mouseDirX, mouseDirY);

    gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    requestAnimationFrame(render);
  }

  // ── Mouse tracking ──
  canvas.addEventListener('mousemove', function(e) {
    var r = canvas.getBoundingClientRect();
    mouseX = (e.clientX - r.left) / r.width;
    mouseY = 1.0 - (e.clientY - r.top) / r.height; // flip Y for GL
  });

  canvas.addEventListener('mouseleave', function() {
    // Drift back to center-right
    mouseX = 0.7; mouseY = 0.5;
  });

  // Touch support
  canvas.addEventListener('touchmove', function(e) {
    e.preventDefault();
    var touch = e.touches[0];
    var r = canvas.getBoundingClientRect();
    mouseX = (touch.clientX - r.left) / r.width;
    mouseY = 1.0 - (touch.clientY - r.top) / r.height;
  }, { passive: false });

  resize();
  render();
  window.addEventListener('resize', resize);
})();
</script>
