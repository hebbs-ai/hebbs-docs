---
// Narrative arc: Auto-tune → TurboQuant → Stock vs HEBBS → Tuning Loop → Proof
// Full dark theme to continue hero energy
---

<!-- Wrapper -->
<div style="color: #E2E8F0;">

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- Section 1: Auto-tune (the dream — first scroll)                -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="py-28 md:py-36 relative overflow-hidden" style="background: linear-gradient(180deg, #050510 0%, #0a0e1c 100%);">
  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-0 w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(245,158,11,0.06) 0%, transparent 70%); transform: translate(-30%, -50%);"></div>

  <div class="relative mx-auto max-w-5xl px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="font-mono text-xs uppercase tracking-[4px] mb-6" style="color: #F59E0B; opacity: 0.7;">Auto-tune</p>
        <h2 class="font-logo text-4xl md:text-5xl font-bold tracking-tight mb-8 leading-tight" style="color: #F8FAFC;">
          Win your evals.<br/>
          <span style="color: #64748B;">Not generic benchmarks.</span>
        </h2>
        <p class="text-lg leading-relaxed mb-6" style="color: #94A3B8;">
          HEBBS profiles your domain, generates evals from your actual data, and tunes retrieval until your agent wins. Every conversation sharpens the next.
        </p>
        <p class="text-lg leading-relaxed" style="color: #94A3B8;">
          The best agents don't cram context. They reason over <strong style="color: #F8FAFC;">relevant memory that refines itself</strong>.
        </p>
      </div>

      <!-- Visual: Auto-tune pipeline -->
      <div class="space-y-3">
        <div class="flex items-center gap-4 rounded-xl p-4 relative" style="background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.2);">
          <div class="absolute inset-0 rounded-xl pointer-events-none" style="box-shadow: 0 0 30px rgba(245,158,11,0.06);"></div>
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(245,158,11,0.15);">
            <span class="font-mono text-sm font-bold" style="color: #F59E0B;">01</span>
          </div>
          <div class="flex-1">
            <span class="text-sm font-semibold" style="color: #F8FAFC;">Profile your domain</span>
            <p class="text-xs mt-0.5" style="color: #64748B;">Classify data shape, map query patterns</p>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl p-4 relative" style="background: rgba(103,232,249,0.04); border: 1px solid rgba(103,232,249,0.15);">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(103,232,249,0.12);">
            <span class="font-mono text-sm font-bold" style="color: #67E8F9;">02</span>
          </div>
          <div class="flex-1">
            <span class="text-sm font-semibold" style="color: #F8FAFC;">Generate evals from your data</span>
            <p class="text-xs mt-0.5" style="color: #64748B;">Real keywords, real queries, strict match</p>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl p-4 relative" style="background: rgba(52,211,153,0.04); border: 1px solid rgba(52,211,153,0.15);">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(52,211,153,0.12);">
            <span class="font-mono text-sm font-bold" style="color: #34D399;">03</span>
          </div>
          <div class="flex-1">
            <span class="text-sm font-semibold" style="color: #F8FAFC;">Tune until you win</span>
            <p class="text-xs mt-0.5" style="color: #64748B;">Strategy, weights, k, cue expansion</p>
          </div>
        </div>

        <div class="flex items-center gap-4 rounded-xl p-4 relative" style="background: rgba(167,139,250,0.04); border: 1px solid rgba(167,139,250,0.15);">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background: rgba(167,139,250,0.12);">
            <span class="font-mono text-sm font-bold" style="color: #A78BFA;">04</span>
          </div>
          <div class="flex-1">
            <span class="text-sm font-semibold" style="color: #F8FAFC;">Compile and deploy</span>
            <p class="text-xs mt-0.5" style="color: #64748B;">Learned rules load before every conversation</p>
          </div>
        </div>

        <!-- Repeat indicator -->
        <div class="flex justify-center pt-2">
          <div class="flex items-center gap-2 rounded-full px-4 py-1.5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
            <svg class="w-3.5 h-3.5" style="color: #F59E0B;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            <span class="font-mono text-[10px]" style="color: #64748B;">Repeats on every content or model change</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- Section 2: TurboQuant (the how — second scroll)                -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="py-28 md:py-36 relative overflow-hidden" style="background: linear-gradient(180deg, #0a0e1c 0%, #0d1018 100%);">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);"></div>
  <!-- Ambient glow -->
  <div class="absolute top-1/2 right-0 w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(103,232,249,0.05) 0%, transparent 70%); transform: translate(30%, -50%);"></div>

  <div class="relative mx-auto max-w-5xl px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <!-- Visual: Compression -->
      <div class="order-2 md:order-1">
        <div class="rounded-2xl p-8 relative" style="background: rgba(103,232,249,0.03); border: 1px solid rgba(103,232,249,0.1);">
          <!-- Before/after compression visual -->
          <div class="space-y-6">
            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="font-mono text-xs uppercase tracking-widest" style="color: #64748B;">Standard embeddings</span>
                <span class="font-mono text-xs" style="color: #64748B;">1536 dim &middot; f32</span>
              </div>
              <div class="h-3 rounded-full overflow-hidden" style="background: rgba(255,255,255,0.05);">
                <div class="h-full rounded-full" style="width: 100%; background: rgba(248,113,113,0.4);"></div>
              </div>
              <p class="font-mono text-xs mt-2 text-right" style="color: #475569;">6 KB per memory</p>
            </div>

            <!-- Arrow -->
            <div class="flex justify-center">
              <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background: rgba(103,232,249,0.08); border: 1px solid rgba(103,232,249,0.2);">
                <svg class="w-5 h-5" style="color: #67E8F9;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="font-mono text-xs uppercase tracking-widest" style="color: #67E8F9;">TurboQuant</span>
                <span class="font-mono text-xs" style="color: #67E8F9;">binary quantized</span>
              </div>
              <div class="h-3 rounded-full overflow-hidden" style="background: rgba(255,255,255,0.05);">
                <div class="h-full rounded-full" style="width: 10%; background: linear-gradient(90deg, #67E8F9, #34D399);"></div>
              </div>
              <p class="font-mono text-xs mt-2 text-right" style="color: #67E8F9;">192 bytes per memory</p>
            </div>
          </div>

          <!-- Stats row -->
          <div class="grid grid-cols-3 gap-4 mt-8 pt-6" style="border-top: 1px solid rgba(103,232,249,0.1);">
            <div class="text-center">
              <div class="font-mono text-2xl font-bold" style="color: #67E8F9;">32x</div>
              <p class="font-mono text-[10px] uppercase tracking-widest mt-1" style="color: #475569;">smaller</p>
            </div>
            <div class="text-center">
              <div class="font-mono text-2xl font-bold" style="color: #34D399;">&lt;2%</div>
              <p class="font-mono text-[10px] uppercase tracking-widest mt-1" style="color: #475569;">recall loss</p>
            </div>
            <div class="text-center">
              <div class="font-mono text-2xl font-bold" style="color: #F59E0B;">10M+</div>
              <p class="font-mono text-[10px] uppercase tracking-widest mt-1" style="color: #475569;">memories</p>
            </div>
          </div>
        </div>
      </div>

      <div class="order-1 md:order-2">
        <p class="font-mono text-xs uppercase tracking-[4px] mb-6" style="color: #67E8F9; opacity: 0.7;">TurboQuant</p>
        <h2 class="font-logo text-4xl md:text-5xl font-bold tracking-tight mb-8 leading-tight" style="color: #F8FAFC;">
          Store more.<br/>
          <span style="color: #64748B;">Pay less. Lose nothing.</span>
        </h2>
        <p class="text-lg leading-relaxed mb-6" style="color: #94A3B8;">
          TurboQuant compresses embeddings to a fraction of their original size while preserving recall quality. Millions of memories fit where thousands used to.
        </p>
        <p class="text-lg leading-relaxed" style="color: #94A3B8;">
          Less storage, less bandwidth, less cost. <strong style="color: #F8FAFC;">Same retrieval precision.</strong>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- Section 3: Stock Memory vs HEBBS                               -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="py-28 md:py-36 relative overflow-hidden" style="background: linear-gradient(180deg, #0d1018 0%, #10141f 50%, #0d1018 100%);">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);"></div>

  <div class="relative mx-auto max-w-5xl px-6">
    <p class="font-mono text-xs uppercase tracking-[4px] mb-6" style="color: #F87171; opacity: 0.7;">The problem</p>
    <h2 class="font-logo text-4xl md:text-5xl font-bold tracking-tight mb-8 leading-tight" style="color: #F8FAFC;">
      Stock memory is already<br/>
      <span style="color: #F87171;">too late.</span>
    </h2>
    <p class="text-lg leading-relaxed mb-14 max-w-2xl" style="color: #94A3B8;">
      Every vector database gives you one strategy: similarity search. One knob: top-k. No evals, no domain profiling, no self-improvement. The gap is non-linear.
    </p>

    <!-- Side-by-side comparison -->
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Stock -->
      <div class="rounded-2xl p-8 relative" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06);">
        <div class="absolute top-4 right-4">
          <span class="font-mono text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full" style="background: rgba(248,113,113,0.1); color: #F87171;">generic</span>
        </div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: rgba(100,116,139,0.1);">
          <svg class="w-6 h-6" style="color: #475569;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
        <p class="font-mono text-sm mb-5" style="color: #64748B;">Standard RAG / Vector DB</p>
        <div class="space-y-3.5">
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> Similarity search only
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> No temporal reasoning
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> No causal chains
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> No domain tuning
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> No contradiction detection
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #64748B;">
            <span style="color: #334155;">&#10005;</span> Retrieval: static forever
          </div>
        </div>
        <div class="mt-8 pt-5 font-mono text-xs" style="border-top: 1px solid rgba(255,255,255,0.04); color: #334155;">
          cosine &gt; 0.7 LIMIT k &mdash; every query, forever
        </div>
      </div>

      <!-- HEBBS -->
      <div class="rounded-2xl p-8 relative" style="background: rgba(245,158,11,0.04); border: 1px solid rgba(245,158,11,0.15); box-shadow: 0 0 60px rgba(245,158,11,0.05);">
        <div class="absolute top-4 right-4">
          <span class="font-mono text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full" style="background: rgba(245,158,11,0.12); color: #F59E0B;">tuned for you</span>
        </div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background: rgba(245,158,11,0.1);">
          <svg class="w-6 h-6" style="color: #F59E0B;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <p class="font-mono text-sm mb-5" style="color: #F59E0B;">HEBBS</p>
        <div class="space-y-3.5">
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #F59E0B;">&#10003;</span> 4 strategies: similarity + temporal + causal + analogical
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #67E8F9;">&#10003;</span> "What happened in order?" &mdash; temporal
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #34D399;">&#10003;</span> "What caused this?" &mdash; causal chains
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #A78BFA;">&#10003;</span> Domain-profiled, eval-tuned, self-improving
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #F87171;">&#10003;</span> Contradictions surface automatically
          </div>
          <div class="flex items-center gap-3 text-sm" style="color: #CBD5E1;">
            <span style="color: #FBBF24;">&#10003;</span> Retrieval: compounds every tune cycle
          </div>
        </div>
        <div class="mt-8 pt-5 font-mono text-xs" style="border-top: 1px solid rgba(245,158,11,0.1); color: #92400E;">
          strategy-selected &middot; weight-tuned &middot; domain-aware
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- Section 4: The Proof (75% to 94%)                              -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="py-28 md:py-36 relative overflow-hidden" style="background: linear-gradient(180deg, #0d1018 0%, #0c1424 50%, #0f172a 100%);">
  <div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);"></div>
  <!-- Big ambient glow behind the numbers -->
  <div class="absolute top-1/2 left-1/2 w-[700px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(52,211,153,0.06) 0%, rgba(245,158,11,0.03) 40%, transparent 70%); transform: translate(-50%, -50%);"></div>

  <div class="relative mx-auto max-w-5xl px-6 text-center">
    <p class="font-mono text-xs uppercase tracking-[4px] mb-6" style="color: #34D399; opacity: 0.7;">The result</p>
    <h2 class="font-logo text-4xl md:text-5xl font-bold tracking-tight mb-3" style="color: #F8FAFC;">
      Same model. Same data.
    </h2>
    <p class="text-xl mb-20" style="color: #64748B;">Different memory engine.</p>

    <!-- Dramatic before/after -->
    <div class="flex items-center justify-center gap-8 md:gap-16 mb-16">
      <div class="text-center">
        <div class="font-mono font-bold leading-none mb-3" style="font-size: clamp(64px, 12vw, 120px); color: rgba(248,113,113,0.6);" data-counter="75">75<span style="font-size: 0.5em;">%</span></div>
        <p class="font-mono text-xs uppercase tracking-widest" style="color: #475569;">stock retrieval</p>
      </div>

      <div class="flex flex-col items-center gap-2">
        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full flex items-center justify-center" style="background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2);">
          <svg class="w-8 h-8 md:w-10 md:h-10" style="color: #F59E0B;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </div>
        <span class="font-mono text-[10px] uppercase tracking-widest" style="color: #F59E0B;">tuned</span>
      </div>

      <div class="text-center">
        <div class="font-mono font-bold leading-none mb-3" style="font-size: clamp(64px, 12vw, 120px); color: #34D399;" data-counter="94">94<span style="font-size: 0.5em;">%</span></div>
        <p class="font-mono text-xs uppercase tracking-widest" style="color: #475569;">HEBBS retrieval</p>
      </div>
    </div>

    <!-- Context bar -->
    <div class="inline-flex flex-wrap items-center justify-center gap-4 rounded-2xl px-8 py-5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full" style="background: #F59E0B;"></div>
        <span class="font-mono text-xs" style="color: #94A3B8;">GPT-4o + OpenAI embeddings</span>
      </div>
      <span style="color: #1E293B;">|</span>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full" style="background: #67E8F9;"></div>
        <span class="font-mono text-xs" style="color: #94A3B8;">Strict keyword recall</span>
      </div>
      <span style="color: #1E293B;">|</span>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full" style="background: #34D399;"></div>
        <span class="font-mono text-xs" style="color: #94A3B8;">Agent-tuned in 60 seconds</span>
      </div>
    </div>

    <p class="mt-10 text-sm" style="color: #475569;">
      +19 percentage points. Not by changing the LLM. By tuning how the agent retrieves.
    </p>
  </div>
</section>

</div>
