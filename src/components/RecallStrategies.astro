---
const strategies = [
  {
    name: "Similarity",
    question: "What looks like this?",
    example: "Find relevant objection responses from past interactions.",
    precision: "~",
    vs: "~",
    color: "text-cyan",
  },
  {
    name: "Temporal",
    question: "What happened, in order?",
    example: "Reconstruct a prospect's full interaction history chronologically.",
    precision: "91%",
    vs: "23%",
    color: "text-accent",
  },
  {
    name: "Causal",
    question: "What caused this outcome?",
    example: "Walk the causal graph backward from a lost deal to find the root cause.",
    precision: "78%",
    vs: "15%",
    color: "text-accent",
  },
  {
    name: "Analogical",
    question: "What's structurally similar in another domain?",
    example: "Apply finance sales patterns to close a healthcare deal.",
    precision: "74%",
    vs: "31%",
    color: "text-accent",
  },
];
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Four recall strategies.
      </h2>
      <p class="text-muted text-lg">
        Most memory systems give you one retrieval mode: similarity search. HEBBS gives you four.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {strategies.map((s) => (
        <div class="rounded-xl border border-border bg-surface/40 p-6 flex flex-col">
          <h3 class="font-mono text-xs uppercase tracking-wider text-accent mb-3">{s.name}</h3>
          <p class="text-text font-medium text-sm mb-3">"{s.question}"</p>
          <p class="text-muted text-sm leading-relaxed flex-1 mb-6">{s.example}</p>
          {s.precision !== "~" ? (
            <div class="border-t border-border pt-4">
              <p class="font-mono text-2xl font-bold {s.color}">{s.precision}</p>
              <p class="text-xs text-muted mt-1">
                precision <span class="text-red">(vs {s.vs} similarity-only)</span>
              </p>
            </div>
          ) : (
            <div class="border-t border-border pt-4">
              <p class="text-xs text-muted">Baseline retrieval mode</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
