---
const codeHtml = `<span class="text-cyan">from</span> <span class="text-text">hebbs</span> <span class="text-cyan">import</span> <span class="text-text">Hebbs</span>

<span class="text-muted"># Connect (or embed — no server needed)</span>
<span class="text-text">e</span> <span class="text-cyan">=</span> <span class="text-text">Hebbs</span>(<span class="text-green">"localhost:6380"</span>)

<span class="text-muted"># Remember — with importance scoring</span>
<span class="text-text">e</span>.<span class="text-text">remember</span>(
    <span class="text-text">experience</span><span class="text-cyan">=</span><span class="text-green">"Prospect mentioned competitor contract expires March 15"</span>,
    <span class="text-text">importance</span><span class="text-cyan">=</span><span class="text-accent">0.95</span>,
    <span class="text-text">context</span><span class="text-cyan">=</span><span class="text-muted">{</span><span class="text-green">"prospect_id"</span>: <span class="text-green">"acme"</span>, <span class="text-green">"signal"</span>: <span class="text-green">"urgency"</span><span class="text-muted">}</span>
)

<span class="text-muted"># Recall — four strategies, one engine</span>
<span class="text-text">history</span>  <span class="text-cyan">=</span> <span class="text-text">e</span>.<span class="text-text">recall</span>(<span class="text-text">cue</span><span class="text-cyan">=</span><span class="text-muted">{</span><span class="text-green">"prospect_id"</span>: <span class="text-green">"acme"</span><span class="text-muted">}</span>, <span class="text-text">strategy</span><span class="text-cyan">=</span><span class="text-green">"temporal"</span>)
<span class="text-text">similar</span>  <span class="text-cyan">=</span> <span class="text-text">e</span>.<span class="text-text">recall</span>(<span class="text-text">cue</span><span class="text-cyan">=</span><span class="text-green">"we built this in-house"</span>, <span class="text-text">strategy</span><span class="text-cyan">=</span><span class="text-green">"similarity"</span>)
<span class="text-text">causes</span>   <span class="text-cyan">=</span> <span class="text-text">e</span>.<span class="text-text">recall</span>(<span class="text-text">cue</span><span class="text-cyan">=</span><span class="text-green">"deal lost after pricing"</span>, <span class="text-text">strategy</span><span class="text-cyan">=</span><span class="text-green">"causal"</span>)
<span class="text-text">patterns</span> <span class="text-cyan">=</span> <span class="text-text">e</span>.<span class="text-text">recall</span>(<span class="text-text">cue</span><span class="text-cyan">=</span><span class="text-green">"healthcare compliance"</span>, <span class="text-text">strategy</span><span class="text-cyan">=</span><span class="text-green">"analogical"</span>)

<span class="text-muted"># Subscribe — memory surfaces automatically</span>
<span class="text-cyan">for</span> <span class="text-text">memory</span> <span class="text-cyan">in</span> <span class="text-text">e</span>.<span class="text-text">subscribe</span>(<span class="text-text">input_stream</span><span class="text-cyan">=</span><span class="text-text">transcript</span>, <span class="text-text">threshold</span><span class="text-cyan">=</span><span class="text-accent">0.8</span>):
    <span class="text-text">inject_into_context</span>(<span class="text-text">memory</span>)

<span class="text-muted"># Reflect — consolidate episodes into insights</span>
<span class="text-text">e</span>.<span class="text-text">reflect_policy</span>(<span class="text-muted">{</span><span class="text-green">"triggers"</span>: [<span class="text-muted">{</span><span class="text-green">"type"</span>: <span class="text-green">"threshold"</span>, <span class="text-green">"new_memories"</span>: <span class="text-accent">50</span><span class="text-muted">}</span>]<span class="text-muted">}</span>)
<span class="text-text">insights</span> <span class="text-cyan">=</span> <span class="text-text">e</span>.<span class="text-text">insights</span>(<span class="text-text">filter</span><span class="text-cyan">=</span><span class="text-muted">{</span><span class="text-green">"topic"</span>: <span class="text-green">"objection handling"</span><span class="text-muted">}</span>)`;
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-4xl px-6">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        50 lines. Not 2,000.
      </h2>
      <p class="text-muted text-lg">
        The full agent memory lifecycle in Python.
      </p>
    </div>

    <div class="rounded-xl border border-border bg-surface/40 overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-border">
        <div class="w-3 h-3 rounded-full bg-red/40"></div>
        <div class="w-3 h-3 rounded-full bg-accent/40"></div>
        <div class="w-3 h-3 rounded-full bg-green/40"></div>
        <span class="ml-2 text-xs text-muted font-mono">main.py</span>
      </div>

      <pre class="p-6 overflow-x-auto text-sm leading-relaxed font-mono"><code set:html={codeHtml} /></pre>
    </div>
  </div>
</section>
